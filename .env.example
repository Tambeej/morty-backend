# ============================================================
# Morty Backend — Environment Variables
# Copy this file to .env and fill in the values.
# NEVER commit .env to version control.
# ============================================================

# --- Server ---
NODE_ENV=development
PORT=5000

# --- CORS ---
# Comma-separated list of allowed frontend origins
ALLOWED_ORIGINS=http://localhost:3000

# --- MongoDB ---
MONGODB_URI=mongodb+srv://<user>:<password>@cluster.mongodb.net/morty?retryWrites=true&w=majority

# --- JWT ---
# Generate with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=your_jwt_secret_here
JWT_EXPIRES_IN=24h
JWT_REFRESH_SECRET=your_refresh_secret_here
JWT_REFRESH_EXPIRES_IN=7d

# --- Cloudinary (file storage / OCR prep) ---
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret

# --- OpenAI (mortgage analysis) ---
OPENAI_API_KEY=sk-...
OPENAI_MODEL=gpt-4o

# --- Email (Nodemailer) ---
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@gmail.com
SMTP_PASS=your_app_password
EMAIL_FROM=noreply@morty.app

# --- Redis (optional — for session cache) ---
REDIS_URL=redis://localhost:6379

# --- Logging ---
LOG_LEVEL=debug
